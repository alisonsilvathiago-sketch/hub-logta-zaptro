# Copie para `.env.local` (front) ou configure no painel de deploy (Vercel, etc.).
#
# Localhost: npm run dev → http://localhost:5174 (ver LOCALHOST.md)
# Defaults em .env.development; chaves sensíveis só em .env.local

VITE_APP_URL=http://localhost:5174
VITE_PORT=5174

# Dev — pré-preenche /registre em localhost (não use em produção)
# VITE_DEV_REGISTER_EMAIL=seu@email.com
# VITE_DEV_REGISTER_PASSWORD=123456
# VITE_DEV_REGISTER_FIRST_NAME=Nome
# VITE_DEV_REGISTER_LAST_NAME=Sobrenome

# URL pública da API de e-mail (SendGrid no `server/`). Em dev com Vite (Hub 5175 ou Zaptro 5174):
#   VITE_ZAPTRO_MAIL_API_URL=/zaptro-mail-api
# (proxy Vite → http://127.0.0.1:8787). Alternativa: http://localhost:8787
# Em produção: `https://mail.seudominio.com` (sem barra final).
VITE_ZAPTRO_MAIL_API_URL=/zaptro-mail-api

# Supabase — inbox / perfis / whatsapp_conversations (só chaves públicas no front)
VITE_SUPABASE_URL=https://rrjnkmgkhbtapumgmhhr.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_SUPABASE_ANON_KEY=eyJ... (anon JWT do painel)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_... (opcional; substitui anon se ativo)
# service_role e sb_secret_* → apenas em apps/zaptro/server/.env (nunca VITE_*)

# Assistente IA (Ollama) — npm run dev + http://localhost:5174/app
# VPS confirmada: VPS-15317843 · AlmaLinux 9.7 · OLLAMA_HOST=0.0.0.0:11434 · llama3.2:latest
# Ver OLLAMA_SETUP.md para testes SSH e firewall.
VITE_OLLAMA_ENABLED=true
VITE_OLLAMA_MODEL=llama3.2
VITE_OLLAMA_BASE_URL=/ollama-api
# Browser NUNCA chama 127.0.0.1:11434 se Ollama está na VPS — use o IP público:
OLLAMA_PROXY_TARGET=http://108.174.151.98:11434
# Ollama no mesmo Mac (só se não usar VPS):
# OLLAMA_PROXY_TARGET=http://127.0.0.1:11434

# WhatsApp — browser em dev usa proxy /evolution-api → VITE_EVOLUTION_API_URL
VITE_EVOLUTION_BASE_URL=/evolution-api
VITE_EVOLUTION_API_URL=https://evolution.zaptro.com.br
VITE_EVOLUTION_USE_EDGE=true
VITE_EVOLUTION_INSTANCE=zaptro
VITE_EVOLUTION_API_MODE=go
# VITE_EVOLUTION_API_KEY=GLOBAL_API_KEY (admin — /instance/create)
# Token da instância no manager (QR, status, mensagens — Evolution GO):
# VITE_EVOLUTION_INSTANCE_API_KEY=token-da-instancia-zaptro
# Secrets no projeto: EVOLUTION_API_URL, EVOLUTION_API_KEY, EVOLUTION_INSTANCE=zaptro
# Fallback dev directo (só se Edge falhar): VITE_EVOLUTION_USE_EDGE=false + VITE_EVOLUTION_API_KEY

# wa-link / inbox (localhost)
# VITE_WA_LINK_DEFAULT_COMPANY_ID=b1111111-1111-4111-8111-111111111111
# VITE_WA_LINK_WEBHOOK_URL=https://rrjnkmgkhbtapumgmhhr.supabase.co/functions/v1/evolution-webhook
# VITE_WA_LINK_DEV_AUTO_LOGIN=true
# VITE_DEV_REGISTER_EMAIL=seu@email.com
# VITE_DEV_REGISTER_PASSWORD=123456

# Variáveis do serviço Node de e-mail: ver `server/env.sample` (SENDGRID_API_KEY, SUPABASE_URL, etc.).
# Google Agenda (OAuth + Maps + Sheets): GOOGLE_OAUTH_*, GOOGLE_MAPS_API_KEY — só em server/.env (nunca VITE_*).
