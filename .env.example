# ------------------------------------------------------------------------------
# HUB-LOGTA-ZAPTRO: CONFIGURAÇÃO DE AMBIENTE (EXEMPLO)
# ------------------------------------------------------------------------------

# 1. SUPABASE (Shared across apps)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# 2. IA / OLLAMA (Hub Logistics Intelligence)
# O Hub usa proxy para /api/ai. Em produção, verifique o vercel.json.
# Localmente, aponte para seu IP ou localhost:11434
VITE_AI_API_URL=http://localhost:11434

# 3. ZAPTRO MAIL API (Transactional Emails)
# URL da API Node/Express em apps/zaptro/server
VITE_ZAPTRO_MAIL_API_URL=http://localhost:8787
SENDGRID_API_KEY=your-sendgrid-key
REDIS_URL=redis://localhost:6379 # Opcional para BullMQ

# 4. EVOLUTION API (WhatsApp Management)
# Usado no módulo de conexões do Zaptro
VITE_EVOLUTION_API_URL=https://your-evolution-api.com
VITE_EVOLUTION_API_KEY=your-api-key

# 5. APP ZAPTRO (Deep links a partir do Hub Master — /master/zaptro)
# Ex.: http://localhost:5174 ou https://app.zaptro.com.br
VITE_ZAPTRO_APP_ORIGIN=http://localhost:5174

# 6. RELEASE (Identificação de Build)
VITE_APP_RELEASE=1.0.0-dev
